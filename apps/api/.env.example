PORT=4000
DATABASE_URL=postgres://postgres:password@localhost:5432/dispatch_db
JWT_SECRET=change-this-in-production
APP_URL=http://localhost:3000

# Driver license photo uploads (absolute path, outside project directory)
# Local dev example:
UPLOAD_ROOT=~/uploads/smart-dispatch
# Production example:
# UPLOAD_ROOT=/var/smart-dispatch/uploads

# Optional: seed an administrator on first startup
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=System Administrator

# Customer invoice payments (Telebirr / CBE Birr instructions on invoice detail)
# PAYMENT_TELEBIRR_ENABLED=true
# PAYMENT_TELEBIRR_MERCHANT_NAME=Smart Dispatch
# PAYMENT_TELEBIRR_SHORT_CODE=123456
# PAYMENT_TELEBIRR_USSD=*127#
# PAYMENT_CBE_ENABLED=true
# PAYMENT_CBE_ACCOUNT_NAME=Smart Dispatch PLC
# PAYMENT_CBE_ACCOUNT_NUMBER=1000123456789
