generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id           String     @id @default(uuid()) @db.Uuid
  slug         String     @unique @db.VarChar(50)
  translations Json       @db.JsonB
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  authRoles    AuthRole[]

  @@map("roles")
}

enum AccountStatus {
  active
  suspended
  deactivated
}

enum AccountActivation {
  pending
  activated
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique @db.VarChar(255)
  passwordHash      String            @map("password_hash") @db.VarChar(255)
  firstName         String            @map("first_name") @db.VarChar(100)
  middleName        String?           @map("middle_name") @db.VarChar(100)
  lastName          String            @map("last_name") @db.VarChar(100)
  mobileNumber      String            @unique @map("mobile_number") @db.VarChar(20)
  accountStatus     AccountStatus     @default(active) @map("account_status")
  accountActivation AccountActivation @default(pending) @map("account_activation")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  authRoles         AuthRole[]
  tokens            Token[]

  @@index([email])
  @@index([mobileNumber])
  @@map("users")
}

model AuthRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("auth_roles")
}

enum TokenType {
  refresh
  password_reset
}

model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  type      TokenType
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("tokens")
}
