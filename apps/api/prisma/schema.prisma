generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(50)
  translations    Json             @db.JsonB
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  authRoles       AuthRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  module          String           @db.VarChar(50)
  action          String           @db.VarChar(50)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  menuPermissions MenuPermission[]
  endpoints       Endpoint[]
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model MenuPermission {
  menuId       String     @map("menu_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([menuId, permissionId])
  @@index([permissionId])
  @@map("menu_permissions")
}

model Menu {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  path            String?          @db.VarChar(255)
  icon            String?          @db.VarChar(100)
  parentId        String?          @map("parent_id") @db.Uuid
  sortOrder       Int              @default(0) @map("sort_order")
  translations    Json             @db.JsonB
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  parent          Menu?            @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Menu[]           @relation("MenuHierarchy")
  menuPermissions MenuPermission[]

  @@index([parentId])
  @@map("menus")
}

model Endpoint {
  id           String      @id @default(uuid()) @db.Uuid
  slug         String      @unique @db.VarChar(100)
  method       HttpMethod
  path         String      @db.VarChar(255)
  description  String?
  permissionId String?     @map("permission_id") @db.Uuid
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@unique([method, path])
  @@index([permissionId])
  @@map("endpoints")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum AccountStatus {
  active
  suspended
  deactivated
}

enum AccountActivation {
  pending
  activated
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique @db.VarChar(255)
  passwordHash      String            @map("password_hash") @db.VarChar(255)
  firstName         String            @map("first_name") @db.VarChar(100)
  middleName        String?           @map("middle_name") @db.VarChar(100)
  lastName          String            @map("last_name") @db.VarChar(100)
  mobileNumber      String            @unique @map("mobile_number") @db.VarChar(20)
  accountStatus     AccountStatus     @default(active) @map("account_status")
  accountActivation AccountActivation @default(pending) @map("account_activation")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  authRoles         AuthRole[]
  tokens            Token[]

  @@index([email])
  @@index([mobileNumber])
  @@map("users")
}

model AuthRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("auth_roles")
}

enum TokenType {
  refresh
  password_reset
}

model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  type      TokenType
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("tokens")
}
