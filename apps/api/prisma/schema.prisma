generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(50)
  translations    Json             @db.JsonB
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  authRoles       AuthRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  module          String           @db.VarChar(50)
  action          String           @db.VarChar(50)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  menuPermissions MenuPermission[]
  endpoints       Endpoint[]
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model MenuPermission {
  menuId       String     @map("menu_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([menuId, permissionId])
  @@index([permissionId])
  @@map("menu_permissions")
}

model Menu {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  path            String?          @db.VarChar(255)
  icon            String?          @db.VarChar(100)
  parentId        String?          @map("parent_id") @db.Uuid
  sortOrder       Int              @default(0) @map("sort_order")
  translations    Json             @db.JsonB
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  parent          Menu?            @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Menu[]           @relation("MenuHierarchy")
  menuPermissions MenuPermission[]

  @@index([parentId])
  @@map("menus")
}

model Endpoint {
  id           String      @id @default(uuid()) @db.Uuid
  slug         String      @unique @db.VarChar(100)
  method       HttpMethod
  path         String      @db.VarChar(255)
  description  String?
  permissionId String?     @map("permission_id") @db.Uuid
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@unique([method, path])
  @@index([permissionId])
  @@map("endpoints")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum AccountStatus {
  active
  suspended
  deactivated
}

enum AccountActivation {
  pending
  activated
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique @db.VarChar(255)
  passwordHash      String            @map("password_hash") @db.VarChar(255)
  firstName         String            @map("first_name") @db.VarChar(100)
  middleName        String?           @map("middle_name") @db.VarChar(100)
  lastName          String            @map("last_name") @db.VarChar(100)
  mobileNumber      String            @unique @map("mobile_number") @db.VarChar(20)
  accountStatus     AccountStatus     @default(active) @map("account_status")
  accountActivation AccountActivation @default(pending) @map("account_activation")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  authRoles         AuthRole[]
  tokens            Token[]
  auditLogs         AuditLog[]
  driverProfile     Driver?
  assignedVehicle   Vehicle?   @relation("VehicleAssignedDriver")

  @@index([email])
  @@index([mobileNumber])
  @@map("users")
}

model Driver {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  licenseNumber   String   @unique @map("license_number") @db.VarChar(50)
  licensePhotoUrl String?  @map("license_photo_url") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([licenseNumber])
  @@map("drivers")
}

model AuthRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("auth_roles")
}

enum TokenType {
  refresh
  password_reset
}

enum NotificationChannel {
  email
  sms

  @@map("notification_channel")
}

model NotificationConfiguration {
  id        String              @id @default(uuid()) @db.Uuid
  channel   NotificationChannel @unique
  isEnabled Boolean             @default(false) @map("is_enabled")
  provider  String?             @db.VarChar(100)
  fromEmail String?             @map("from_email") @db.VarChar(255)
  fromName  String?             @map("from_name") @db.VarChar(255)
  replyTo   String?             @map("reply_to") @db.VarChar(255)
  senderId  String?             @map("sender_id") @db.VarChar(100)
  settings  Json                @default("{}") @db.JsonB
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("notification_configurations")
}

model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  type      TokenType
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("tokens")
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  assign
  revoke
  test

  @@map("audit_action")
}

model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  actorUserId   String?     @map("actor_user_id") @db.Uuid
  action        AuditAction
  module        String      @db.VarChar(50)
  entityType    String      @map("entity_type") @db.VarChar(50)
  entityId      String?     @map("entity_id") @db.VarChar(255)
  entityLabel   String?     @map("entity_label") @db.VarChar(255)
  summary       String?     @db.VarChar(500)
  metadata      Json        @default("{}") @db.JsonB
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  userAgent     String?     @map("user_agent") @db.VarChar(512)
  requestMethod String?     @map("request_method") @db.VarChar(10)
  requestPath   String?     @map("request_path") @db.VarChar(255)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  actor         User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum VehicleStatus {
  active
  maintenance
  retired

  @@map("vehicle_status")
}

model VehicleType {
  id                String    @id @default(uuid()) @db.Uuid
  slug              String    @unique @db.VarChar(50)
  translations      Json      @db.JsonB
  passengerCapacity Int?      @map("passenger_capacity")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  vehicles          Vehicle[]
  farePlans         FarePlan[]

  @@map("vehicle_types")
}

model Vehicle {
  id                   String        @id @default(uuid()) @db.Uuid
  plateNumber          String        @unique @map("plate_number") @db.VarChar(30)
  chassisNumber        String?       @unique @map("chassis_number") @db.VarChar(50)
  vehicleTypeId        String        @map("vehicle_type_id") @db.Uuid
  assignedDriverUserId String?       @unique @map("assigned_driver_user_id") @db.Uuid
  make                 String?       @db.VarChar(100)
  model                String?       @db.VarChar(100)
  year                 Int?
  status               VehicleStatus @default(active)
  notes                String?       @db.Text
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  vehicleType          VehicleType   @relation(fields: [vehicleTypeId], references: [id], onDelete: Restrict)
  assignedDriver       User?         @relation("VehicleAssignedDriver", fields: [assignedDriverUserId], references: [id], onDelete: SetNull)

  @@index([vehicleTypeId])
  @@index([status])
  @@index([assignedDriverUserId])
  @@map("vehicles")
}

model Region {
  id           String     @id @default(uuid()) @db.Uuid
  slug         String     @unique @db.VarChar(50)
  translations Json       @db.JsonB
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  locations    Location[]
  farePlans    FarePlan[]

  @@map("regions")
}

model Location {
  id           String   @id @default(uuid()) @db.Uuid
  regionId     String   @map("region_id") @db.Uuid
  translations Json     @db.JsonB
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  address      String?  @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  region       Region   @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@index([regionId])
  @@map("locations")
}

enum PricingModel {
  flat
  distance
  time
  distance_time
  hourly

  @@map("pricing_model")
}

model FarePlan {
  id                 String        @id @default(uuid()) @db.Uuid
  slug               String        @unique @db.VarChar(50)
  translations       Json          @db.JsonB
  vehicleTypeId      String?       @map("vehicle_type_id") @db.Uuid
  regionId           String?       @map("region_id") @db.Uuid
  pricingModel       PricingModel  @map("pricing_model")
  currency           String        @default("ETB") @db.VarChar(3)
  baseFare           Decimal       @map("base_fare") @db.Decimal(12, 2)
  perKmRate          Decimal?      @map("per_km_rate") @db.Decimal(12, 2)
  perMinuteRate      Decimal?      @map("per_minute_rate") @db.Decimal(12, 2)
  minimumFare        Decimal?      @map("minimum_fare") @db.Decimal(12, 2)
  bookingFee         Decimal?      @map("booking_fee") @db.Decimal(12, 2)
  freeWaitingMinutes Int?          @map("free_waiting_minutes")
  waitingFeePerMinute Decimal?     @map("waiting_fee_per_minute") @db.Decimal(12, 2)
  priority           Int           @default(0)
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  vehicleType        VehicleType?  @relation(fields: [vehicleTypeId], references: [id], onDelete: SetNull)
  region             Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([vehicleTypeId])
  @@index([regionId])
  @@index([pricingModel])
  @@index([isActive])
  @@map("fare_plans")
}
