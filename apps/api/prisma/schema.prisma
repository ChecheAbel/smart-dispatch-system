generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(50)
  translations    Json             @db.JsonB
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  authRoles       AuthRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  module          String           @db.VarChar(50)
  action          String           @db.VarChar(50)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  menuPermissions MenuPermission[]
  endpoints       Endpoint[]
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model MenuPermission {
  menuId       String     @map("menu_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([menuId, permissionId])
  @@index([permissionId])
  @@map("menu_permissions")
}

model Menu {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(100)
  path            String?          @db.VarChar(255)
  icon            String?          @db.VarChar(100)
  parentId        String?          @map("parent_id") @db.Uuid
  sortOrder       Int              @default(0) @map("sort_order")
  translations    Json             @db.JsonB
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  parent          Menu?            @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Menu[]           @relation("MenuHierarchy")
  menuPermissions MenuPermission[]

  @@index([parentId])
  @@map("menus")
}

model Endpoint {
  id           String      @id @default(uuid()) @db.Uuid
  slug         String      @unique @db.VarChar(100)
  method       HttpMethod
  path         String      @db.VarChar(255)
  description  String?
  permissionId String?     @map("permission_id") @db.Uuid
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  @@unique([method, path])
  @@index([permissionId])
  @@map("endpoints")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum AccountStatus {
  active
  suspended
  deactivated
}

enum AccountActivation {
  pending
  activated
}

enum RequesterSegment {
  individual
  business
  government
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique @db.VarChar(255)
  passwordHash      String            @map("password_hash") @db.VarChar(255)
  firstName         String            @map("first_name") @db.VarChar(100)
  middleName        String?           @map("middle_name") @db.VarChar(100)
  lastName          String            @map("last_name") @db.VarChar(100)
  mobileNumber      String            @unique @map("mobile_number") @db.VarChar(20)
  accountStatus     AccountStatus     @default(active) @map("account_status")
  accountActivation AccountActivation @default(pending) @map("account_activation")
  accountBlockReason String?          @map("account_block_reason") @db.VarChar(500)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  authRoles         AuthRole[]
  tokens            Token[]
  auditLogs         AuditLog[]
  driverProfile     Driver?
  requesterProfile  RequesterProfile?
  assignedVehicle   Vehicle?   @relation("VehicleAssignedDriver")
  rideRequests      RideRequest[]
  assignedDispatchRideRequests RideRequest[] @relation("RideRequestAssignedDriver")
  vehicleMaintenanceLogs VehicleMaintenanceLog[] @relation("VehicleMaintenanceCreatedBy")
  vehicleHistoryEvents   VehicleHistoryEvent[] @relation("VehicleHistoryActor")

  @@index([email])
  @@index([mobileNumber])
  @@map("users")
}

model RequesterProfile {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @unique @map("user_id") @db.Uuid
  segment              RequesterSegment
  organizationName     String?          @map("organization_name") @db.VarChar(200)
  jobTitle             String?          @map("job_title") @db.VarChar(100)
  organizationAddress  String?          @map("organization_address") @db.VarChar(500)
  taxId                String?          @map("tax_id") @db.VarChar(50)
  registrationNumber   String?          @map("registration_number") @db.VarChar(50)
  governmentEntityType String?          @map("government_entity_type") @db.VarChar(100)
  officialReference    String?          @map("official_reference") @db.VarChar(100)
  billingContactName   String?          @map("billing_contact_name") @db.VarChar(100)
  billingContactEmail  String?          @map("billing_contact_email") @db.VarChar(255)
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([segment])
  @@map("requester_profiles")
}

model Driver {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  licenseNumber   String   @unique @map("license_number") @db.VarChar(50)
  licensePhotoUrl String?  @map("license_photo_url") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([licenseNumber])
  @@map("drivers")
}

model AuthRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("auth_roles")
}

enum TokenType {
  refresh
  password_reset
}

enum NotificationChannel {
  email
  sms

  @@map("notification_channel")
}

enum NotificationModule {
  ride_requests
  user_registrations

  @@map("notification_module")
}

enum NotificationTemplateRecipient {
  requester
  driver
  applicant

  @@map("notification_template_recipient")
}

model NotificationConfiguration {
  id        String              @id @default(uuid()) @db.Uuid
  channel   NotificationChannel @unique
  isEnabled Boolean             @default(false) @map("is_enabled")
  provider  String?             @db.VarChar(100)
  fromEmail String?             @map("from_email") @db.VarChar(255)
  fromName  String?             @map("from_name") @db.VarChar(255)
  replyTo   String?             @map("reply_to") @db.VarChar(255)
  senderId  String?             @map("sender_id") @db.VarChar(100)
  settings  Json                @default("{}") @db.JsonB
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("notification_configurations")
}

model NotificationTemplate {
  id        String                        @id @default(uuid()) @db.Uuid
  module    NotificationModule
  event     String                        @db.VarChar(50)
  channel   NotificationChannel
  recipient NotificationTemplateRecipient
  isEnabled Boolean                       @default(false) @map("is_enabled")
  subject   String?                       @db.VarChar(255)
  body          String                        @db.VarChar(2000)
  createdAt     DateTime                      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                      @updatedAt @map("updated_at") @db.Timestamptz
  deliveryLogs  NotificationDeliveryLog[]

  @@unique([module, event, channel, recipient])
  @@map("notification_templates")
}

enum NotificationDeliveryStatus {
  sent
  skipped
  failed

  @@map("notification_delivery_status")
}

model NotificationDeliveryLog {
  id               String                        @id @default(uuid()) @db.Uuid
  status           NotificationDeliveryStatus
  module           NotificationModule
  event            String                        @db.VarChar(50)
  channel          NotificationChannel
  recipient        NotificationTemplateRecipient
  templateId       String?                       @map("template_id") @db.Uuid
  entityType       String?                       @map("entity_type") @db.VarChar(50)
  entityId         String?                       @map("entity_id") @db.VarChar(255)
  recipientContact String?                       @map("recipient_contact") @db.VarChar(255)
  subject          String?                       @db.VarChar(255)
  bodyPreview      String?                       @map("body_preview") @db.VarChar(500)
  errorMessage     String?                       @map("error_message") @db.VarChar(500)
  isTest           Boolean                       @default(false) @map("is_test")
  createdAt        DateTime                      @default(now()) @map("created_at") @db.Timestamptz
  template         NotificationTemplate?         @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([module, event])
  @@map("notification_delivery_logs")
}

model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  type      TokenType
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("tokens")
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  assign
  revoke
  test

  @@map("audit_action")
}

model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  actorUserId   String?     @map("actor_user_id") @db.Uuid
  action        AuditAction
  module        String      @db.VarChar(50)
  entityType    String      @map("entity_type") @db.VarChar(50)
  entityId      String?     @map("entity_id") @db.VarChar(255)
  entityLabel   String?     @map("entity_label") @db.VarChar(255)
  summary       String?     @db.VarChar(500)
  metadata      Json        @default("{}") @db.JsonB
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  userAgent     String?     @map("user_agent") @db.VarChar(512)
  requestMethod String?     @map("request_method") @db.VarChar(10)
  requestPath   String?     @map("request_path") @db.VarChar(255)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  actor         User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum VehicleStatus {
  active
  maintenance
  retired

  @@map("vehicle_status")
}

model VehicleType {
  id                String             @id @default(uuid()) @db.Uuid
  slug              String             @unique @db.VarChar(50)
  translations      Json               @db.JsonB
  passengerCapacity Int?               @map("passenger_capacity")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  vehicles          Vehicle[]
  farePlans         FarePlan[]
  rideRequests      RideRequest[]
  vehicleClassLinks VehicleTypeClass[]

  @@map("vehicle_types")
}

model VehicleClass {
  id                String             @id @default(uuid()) @db.Uuid
  slug              String             @unique @db.VarChar(50)
  translations      Json               @db.JsonB
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  vehicles          Vehicle[]
  farePlans         FarePlan[]
  rideRequests      RideRequest[]
  vehicleTypeLinks  VehicleTypeClass[]

  @@map("vehicle_classes")
}

model VehicleTypeClass {
  vehicleTypeId  String       @map("vehicle_type_id") @db.Uuid
  vehicleClassId String       @map("vehicle_class_id") @db.Uuid
  vehicleType    VehicleType  @relation(fields: [vehicleTypeId], references: [id], onDelete: Cascade)
  vehicleClass   VehicleClass @relation(fields: [vehicleClassId], references: [id], onDelete: Cascade)

  @@id([vehicleTypeId, vehicleClassId])
  @@index([vehicleClassId])
  @@map("vehicle_type_classes")
}

model Vehicle {
  id                       String        @id @default(uuid()) @db.Uuid
  plateNumber              String        @unique @map("plate_number") @db.VarChar(30)
  chassisNumber            String?       @unique @map("chassis_number") @db.VarChar(50)
  vehicleTypeId            String        @map("vehicle_type_id") @db.Uuid
  vehicleClassId           String        @map("vehicle_class_id") @db.Uuid
  assignedDriverUserId     String?       @unique @map("assigned_driver_user_id") @db.Uuid
  make                     String?       @db.VarChar(100)
  model                    String?       @db.VarChar(100)
  year                     Int?
  status                   VehicleStatus @default(active)
  notes                    String?       @db.Text
  insuranceProvider        String?       @map("insurance_provider") @db.VarChar(150)
  insurancePolicyNumber    String?       @map("insurance_policy_number") @db.VarChar(80)
  insuranceIssuedAt        DateTime?     @map("insurance_issued_at") @db.Date
  insuranceExpiresAt       DateTime?     @map("insurance_expires_at") @db.Date
  insuranceNotes           String?       @map("insurance_notes") @db.Text
  inspectionCenter         String?       @map("inspection_center") @db.VarChar(150)
  inspectionCertificateNumber String?    @map("inspection_certificate_number") @db.VarChar(80)
  inspectionPerformedAt    DateTime?     @map("inspection_performed_at") @db.Date
  inspectionExpiresAt      DateTime?     @map("inspection_expires_at") @db.Date
  inspectionNotes          String?       @map("inspection_notes") @db.Text
  registrationExpiresAt    DateTime?     @map("registration_expires_at") @db.Date
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  vehicleType              VehicleType   @relation(fields: [vehicleTypeId], references: [id], onDelete: Restrict)
  vehicleClass             VehicleClass  @relation(fields: [vehicleClassId], references: [id], onDelete: Restrict)
  assignedDriver           User?         @relation("VehicleAssignedDriver", fields: [assignedDriverUserId], references: [id], onDelete: SetNull)
  rideRequestAssignments   RideRequest[] @relation("RideRequestAssignedVehicle")
  maintenanceLogs          VehicleMaintenanceLog[]
  historyEvents            VehicleHistoryEvent[]

  @@index([vehicleTypeId])
  @@index([vehicleClassId])
  @@index([status])
  @@index([assignedDriverUserId])
  @@index([insuranceExpiresAt])
  @@index([inspectionExpiresAt])
  @@index([registrationExpiresAt])
  @@map("vehicles")
}

enum VehicleMaintenanceStatus {
  open
  in_progress
  completed
  cancelled

  @@map("vehicle_maintenance_status")
}

model MaintenanceWorkType {
  id           String                  @id @default(uuid()) @db.Uuid
  slug         String                  @unique @db.VarChar(50)
  translations Json                    @db.JsonB
  isActive     Boolean                 @default(true) @map("is_active")
  sortOrder    Int                     @default(0) @map("sort_order")
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz
  maintenanceLogs VehicleMaintenanceLog[]

  @@map("maintenance_work_types")
}

model VehicleMaintenanceLog {
  id           String                    @id @default(uuid()) @db.Uuid
  vehicleId    String                    @map("vehicle_id") @db.Uuid
  workTypeId   String                    @map("work_type_id") @db.Uuid
  status       VehicleMaintenanceStatus  @default(open)
  title        String                    @db.VarChar(200)
  description  String?                   @db.Text
  vendor       String?                   @db.VarChar(200)
  costAmount   Decimal?                  @map("cost_amount") @db.Decimal(12, 2)
  odometerKm   Int?                      @map("odometer_km")
  startedAt    DateTime?                 @map("started_at") @db.Date
  completedAt  DateTime?                 @map("completed_at") @db.Date
  nextDueAt    DateTime?                 @map("next_due_at") @db.Date
  nextDueKm    Int?                      @map("next_due_km")
  createdById  String?                   @map("created_by_id") @db.Uuid
  createdAt    DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  vehicle      Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  workType     MaintenanceWorkType       @relation(fields: [workTypeId], references: [id], onDelete: Restrict)
  createdBy    User?                     @relation("VehicleMaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([vehicleId, createdAt])
  @@index([status])
  @@index([workTypeId])
  @@map("vehicle_maintenance_logs")
}

enum VehicleHistoryEventType {
  created
  status_changed
  driver_assigned
  driver_unassigned
  maintenance_opened
  maintenance_updated
  maintenance_completed
  maintenance_cancelled
  expiry_updated

  @@map("vehicle_history_event_type")
}

model VehicleHistoryEvent {
  id          String                  @id @default(uuid()) @db.Uuid
  vehicleId   String                  @map("vehicle_id") @db.Uuid
  eventType   VehicleHistoryEventType @map("event_type")
  summary     String                  @db.VarChar(500)
  metadata    Json                    @default("{}") @db.JsonB
  actorUserId String?                 @map("actor_user_id") @db.Uuid
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz
  vehicle     Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  actor       User?                   @relation("VehicleHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([vehicleId, createdAt])
  @@index([eventType])
  @@map("vehicle_history_events")
}

model Region {
  id           String     @id @default(uuid()) @db.Uuid
  slug         String     @unique @db.VarChar(50)
  translations Json       @db.JsonB
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  locations    Location[]
  farePlans    FarePlan[]
  rideRequests RideRequest[]

  @@map("regions")
}

model Location {
  id           String   @id @default(uuid()) @db.Uuid
  regionId     String   @map("region_id") @db.Uuid
  translations Json     @db.JsonB
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  address      String?  @db.VarChar(255)
  canPickup    Boolean  @default(true) @map("can_pickup")
  canDropoff   Boolean  @default(true) @map("can_dropoff")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  region       Region   @relation(fields: [regionId], references: [id], onDelete: Restrict)
  pickupRideRequests  RideRequest[] @relation("RideRequestPickupLocation")
  dropoffRideRequests RideRequest[] @relation("RideRequestDropoffLocation")

  @@index([regionId])
  @@index([canPickup])
  @@index([canDropoff])
  @@map("locations")
}

enum PricingModel {
  flat
  distance
  time
  distance_time
  hourly

  @@map("pricing_model")
}

model FarePlan {
  id                 String        @id @default(uuid()) @db.Uuid
  slug               String        @unique @db.VarChar(50)
  translations       Json          @db.JsonB
  vehicleTypeId      String?       @map("vehicle_type_id") @db.Uuid
  vehicleClassId     String?       @map("vehicle_class_id") @db.Uuid
  regionId           String?       @map("region_id") @db.Uuid
  pricingModel       PricingModel  @map("pricing_model")
  currency           String        @default("ETB") @db.VarChar(3)
  baseFare           Decimal       @map("base_fare") @db.Decimal(12, 2)
  perKmRate          Decimal?      @map("per_km_rate") @db.Decimal(12, 2)
  perMinuteRate      Decimal?      @map("per_minute_rate") @db.Decimal(12, 2)
  minimumFare        Decimal?      @map("minimum_fare") @db.Decimal(12, 2)
  bookingFee         Decimal?      @map("booking_fee") @db.Decimal(12, 2)
  freeWaitingMinutes Int?          @map("free_waiting_minutes")
  waitingFeePerMinute Decimal?     @map("waiting_fee_per_minute") @db.Decimal(12, 2)
  priority           Int           @default(0)
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  vehicleType        VehicleType?  @relation(fields: [vehicleTypeId], references: [id], onDelete: SetNull)
  vehicleClass       VehicleClass? @relation(fields: [vehicleClassId], references: [id], onDelete: SetNull)
  region             Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([vehicleTypeId])
  @@index([vehicleClassId])
  @@index([regionId])
  @@index([pricingModel])
  @@index([isActive])
  @@map("fare_plans")
}

enum RideRequestStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled

  @@map("ride_request_status")
}

model RideRequest {
  id               String            @id @default(uuid()) @db.Uuid
  requesterUserId  String            @map("requester_user_id") @db.Uuid
  vehicleTypeId    String?           @map("vehicle_type_id") @db.Uuid
  vehicleClassId   String?           @map("vehicle_class_id") @db.Uuid
  regionId         String?           @map("region_id") @db.Uuid
  pickupLocationId String?           @map("pickup_location_id") @db.Uuid
  dropoffLocationId String?          @map("dropoff_location_id") @db.Uuid
  pickupAddress    String            @map("pickup_address") @db.VarChar(500)
  pickupLatitude   Decimal?          @map("pickup_latitude") @db.Decimal(10, 7)
  pickupLongitude  Decimal?          @map("pickup_longitude") @db.Decimal(10, 7)
  dropoffAddress   String            @map("dropoff_address") @db.VarChar(500)
  dropoffLatitude  Decimal?          @map("dropoff_latitude") @db.Decimal(10, 7)
  dropoffLongitude Decimal?          @map("dropoff_longitude") @db.Decimal(10, 7)
  scheduledAt      DateTime?         @map("scheduled_at") @db.Timestamptz
  passengerCount   Int               @default(1) @map("passenger_count")
  notes            String?           @db.VarChar(1000)
  status           RideRequestStatus @default(pending)
  rejectionReason  String?           @map("rejection_reason") @db.VarChar(500)
  assignedVehicleId    String?       @map("assigned_vehicle_id") @db.Uuid
  assignedDriverUserId String?       @map("assigned_driver_user_id") @db.Uuid
  assignedAt           DateTime?     @map("assigned_at") @db.Timestamptz
  startedAt            DateTime?     @map("started_at") @db.Timestamptz
  completedAt          DateTime?     @map("completed_at") @db.Timestamptz
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  requester        User              @relation(fields: [requesterUserId], references: [id], onDelete: Cascade)
  vehicleType      VehicleType?      @relation(fields: [vehicleTypeId], references: [id], onDelete: SetNull)
  vehicleClass     VehicleClass?     @relation(fields: [vehicleClassId], references: [id], onDelete: SetNull)
  region           Region?           @relation(fields: [regionId], references: [id], onDelete: SetNull)
  pickupLocation   Location?         @relation("RideRequestPickupLocation", fields: [pickupLocationId], references: [id], onDelete: SetNull)
  dropoffLocation  Location?         @relation("RideRequestDropoffLocation", fields: [dropoffLocationId], references: [id], onDelete: SetNull)
  assignedVehicle  Vehicle?          @relation("RideRequestAssignedVehicle", fields: [assignedVehicleId], references: [id], onDelete: SetNull)
  assignedDriver   User?             @relation("RideRequestAssignedDriver", fields: [assignedDriverUserId], references: [id], onDelete: SetNull)

  @@index([requesterUserId])
  @@index([vehicleClassId])
  @@index([status])
  @@index([assignedVehicleId])
  @@index([assignedDriverUserId])
  @@index([pickupLocationId])
  @@index([dropoffLocationId])
  @@index([createdAt(sort: Desc)])
  @@map("ride_requests")
}
